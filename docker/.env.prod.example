
# Tirix AI — Production Environment Template


# ── General ─────────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# ── Database & Redis ────────────────────────────────────
DATABASE_URL=postgresql://platform:platform_db_password_here@postgres:5432/platform
REDIS_URL=redis://redis:6379/0

# ── Auth (JWT) ──────────────────────────────────────────
JWT_SECRET_KEY=generate_a_very_long_random_string_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Gateway API Key ─────────────────────────────────────
GATEWAY_API_KEY=sk-gw-generate_a_random_string_here

# ── AWS Credentials (For S3 Object Storage) ─────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# ── Object Storage (S3) ─────────────────────────────────
AWS_S3_BUCKET_NAME=your-s3-bucket-name

# ── LLM Configuration ───────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# ── Resend (Email Notifications) ────────────────────────
RESEND_API_KEY=re_your_api_key_here

# ── Grafana ─────────────────────────────────────────────
GF_SECURITY_ADMIN_PASSWORD=change_this_admin_password_here

# ── Celery ──────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
